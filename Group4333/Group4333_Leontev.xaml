<Window x:Class="Group4333.Group4333_Leontev"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Group4333"
        mc:Ignorable="d"
        Title="Group4333_Leontev"
        Height="520"
        Width="820"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Информация об авторе -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0 5 0 10">
            <TextBlock Text="ФИО: Леонтьев Егор Вячеславович  |  "
                       FontSize="13" FontWeight="Bold"/>
            <TextBlock Text="Возраст: 18 лет  |  " FontSize="13"/>
            <TextBlock Text="Группа: 4333" FontSize="13" FontWeight="Bold"/>
        </StackPanel>

        <!-- Кнопки + статус -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 0 0 8">
            <Button Content="📂  Импорт данных"
                    Width="150" Height="32"
                    Margin="0 0 10 0"
                    Background="#4472C4" Foreground="White"
                    FontWeight="Bold"
                    Click="ImportData_Click"/>
            <Button Content="💾  Экспорт в Excel"
                    Width="150" Height="32"
                    Margin="0 0 10 0"
                    Background="#70AD47" Foreground="White"
                    FontWeight="Bold"
                    Click="ExportToExcel_Click"/>
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       FontStyle="Italic"
                       Foreground="#555555"
                       Text="Загрузите данные из файла 2.xlsx"/>
        </StackPanel>

        <!-- Таблица данных -->
        <DataGrid Grid.Row="2"
                  x:Name="OrdersGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All"
                  AlternatingRowBackground="#EEF3FF"
                  RowBackground="White"
                  HeadersVisibility="Column"
                  ColumnHeaderHeight="32"
                  RowHeight="26"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#4472C4"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"
                                    Binding="{Binding Id}"
                                    Width="50"/>
                <DataGridTextColumn Header="Код заказа"
                                    Binding="{Binding OrderCode}"
                                    Width="120"/>
                <DataGridTextColumn Header="Дата создания"
                                    Binding="{Binding CreatedDate, StringFormat=dd.MM.yyyy}"
                                    Width="130"/>
                <DataGridTextColumn Header="Код клиента"
                                    Binding="{Binding ClientCode}"
                                    Width="120"/>
                <DataGridTextColumn Header="Услуги"
                                    Binding="{Binding Services}"
                                    Width="180"/>
                <DataGridTextColumn Header="Статус"
                                    Binding="{Binding Status}"
                                    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Счётчик записей -->
        <TextBlock Grid.Row="3"
                   x:Name="CountText"
                   Margin="0 5 0 0"
                   FontSize="12"
                   Foreground="#555555"/>

        <!-- Статус БД -->
        <Border Grid.Row="4"
                Background="#F0F0F0"
                BorderBrush="#CCCCCC"
                BorderThickness="0 1 0 0"
                Margin="0 8 0 0"
                Padding="8 4">
            <TextBlock x:Name="DbStatusText"
                       FontSize="11"
                       Foreground="#333333"
                       Text="База данных: не инициализирована"/>
        </Border>
    </Grid>
</Window>
